# 1. Dependencias (El agujero negro de peso)
/node_modules
/.pnp
.pnp.js

# 2. Archivos de entorno y Secretos (¡CRÍTICO!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# 3. Next.js y Build de Producción
/.next/
/out/
/build
.tsbuildinfo

# 4. Logs y depuración
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
*.log

# 5. Archivos del Sistema Operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 6. Cachés y herramientas de desarrollo
.eslintcache
.stylelintcache
.npm/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# 7. Editores de Código (IDE)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

